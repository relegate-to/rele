{
  "name": "rele",
  "private": true,
  "workspaces": [
    "gate",
    "db"
  ],
  "scripts": {
    "dev:gate": "bun run --filter gate dev",
    "build:gate": "bun run --filter gate build",
    "start:gate": "bun run --filter gate start",
    "db:generate": "bun run --filter @rele/db generate",
    "db:migrate": "bun run --filter @rele/db migrate",
    "db:push": "bun run --filter @rele/db push",
    "db:studio": "bun run --filter @rele/db studio"
  }
}
