#!/bin/bash

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_DIR="$ROOT_DIR/configuration"
CONFIG_REPO="https://github.com/relegate-to/configuration"

case $1 in
  up)
    docker compose -f "$ROOT_DIR/db/supabase/supabase.yml" --env-file "$ROOT_DIR/db/supabase/.env" --project-name supabase up -d
    docker compose -f "$ROOT_DIR/docker-compose.yml" up "${@:2}"
    ;;

  down)
    docker compose -f "$ROOT_DIR/docker-compose.yml" down "${@:2}"
    docker compose -f "$ROOT_DIR/db/supabase/supabase.yml" --project-name supabase down "${@:2}"
    ;;

  nuke)
    echo "Stopping and wiping all Supabase volumes..."
    docker compose -f "$ROOT_DIR/docker-compose.yml" down
    docker compose -f "$ROOT_DIR/db/supabase/supabase.yml" --project-name supabase down -v
    echo "Done."
    ;;

  env:push)
    echo "Cloning configuration..."
    git clone "$CONFIG_REPO" "$CONFIG_DIR"
    echo "Pushing .env files..."
    find "$ROOT_DIR" -name ".env*" \
      -not -path "*/configuration/*" \
      -not -path "*/node_modules/*" \
      | while read file; do
          relative="${file#$ROOT_DIR/}"
          dest="$CONFIG_DIR/$relative"
          mkdir -p "$(dirname "$dest")"
          cp "$file" "$dest"
          echo "  ✓ $relative"
        done
    echo "Committing and pushing..."
    cd "$CONFIG_DIR"
    git add -A
    git commit -m "update env files"
    git push
    cd "$ROOT_DIR"
    echo "Cleaning up..."
    rm -rf "$CONFIG_DIR"
    echo "Done."
    ;;

  env:pull)
    echo "Cloning configuration..."
    git clone "$CONFIG_REPO" "$CONFIG_DIR"
    echo "Applying .env files..."
    find "$CONFIG_DIR" -name ".env*" \
      | while read file; do
          relative="${file#$CONFIG_DIR/}"
          dest="$ROOT_DIR/$relative"
          mkdir -p "$(dirname "$dest")"
          cp "$file" "$dest"
          echo "  ✓ $relative"
        done
    echo "Cleaning up..."
    rm -rf "$CONFIG_DIR"
    echo "Done."
    ;;

  migrate)
    for file in "$ROOT_DIR/db/supabase/supabase/migrations"/*.sql; do
      echo "  Applying $(basename "$file")..."
      docker exec -i supabase-db psql -U postgres -d postgres < "$file"
    done
    echo "Done."
    ;;

  db:reset)
    echo "Resetting database..."
    docker exec -i supabase-db psql -U postgres -d postgres \
      -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"
    echo "Running migrations..."
    for file in "$ROOT_DIR/db/supabase/supabase/migrations"/*.sql; do
      echo "  Applying $(basename "$file")..."
      docker exec -i supabase-db psql -U postgres -d postgres < "$file"
    done
    echo "Done."
    ;;

  *)
    echo "Usage: ./run <command>"
    echo ""
    echo "Commands:"
    echo "  up [args]    Start supabase (detached) then web/gate (foreground)"
    echo "  down [args]  Stop web/gate then supabase"
    echo "  nuke         Stop everything and wipe all Supabase volumes"
    echo "  migrate      Push migrations to the local Supabase database"
    echo "  db:reset     Drop and recreate public schema, then re-run migrations"
    echo "  env:push     Copy env files into configuration repo and push"
    echo "  env:pull     Pull latest configuration and apply env files"
    ;;
esac
